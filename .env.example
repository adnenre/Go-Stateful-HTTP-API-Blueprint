# =============================================================================
# REST API Blueprint – Environment Variables Template
# =============================================================================
# Copy this file to .env and adjust values for your local development.
# Do NOT commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
SERVER_PORT=8080

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
# Credentials for local development (adjust if you change docker-compose.yml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=rest_api_blueprint
POSTGRES_PORT=5432

# Connection URL used by the application (supports variable expansion)
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=disable

# -----------------------------------------------------------------------------
# Redis Cache
# -----------------------------------------------------------------------------
REDIS_PORT=6379
REDIS_URL=localhost:${REDIS_PORT}

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=15m

# -----------------------------------------------------------------------------
# Rate Limiting (requests per second per client IP)
# -----------------------------------------------------------------------------
RATE_LIMIT_PER_SEC=10

# -----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# -----------------------------------------------------------------------------
# Comma‑separated list of allowed origins. Use * for any (not recommended for production).
CORS_ALLOWED_ORIGINS=http://localhost:3000
# Allowed HTTP methods
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# Allowed request headers
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID
# Whether to allow credentials (cookies, authorization headers)
CORS_ALLOW_CREDENTIALS=true

# -----------------------------------------------------------------------------
# HSTS (HTTP Strict Transport Security)
# -----------------------------------------------------------------------------
# Max‑age in seconds for Strict-Transport-Security header.
# Default 1 year = 31536000 seconds. Only sent over HTTPS.
HSTS_MAX_AGE=31536000